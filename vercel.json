{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/scan",
      "destination": "/api/index.py"
    },
    {
      "source": "/scans",
      "destination": "/api/index.py"
    },
    {
      "source": "/scans/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/leaderboard",
      "destination": "/api/index.py"
    },
    {
      "source": "/health",
      "destination": "/api/index.py"
    },
    {
      "source": "/skill.json",
      "destination": "/api/index.py"
    },
    {
      "source": "/openapi.json",
      "destination": "/api/index.py"
    },
    {
      "source": "/docs",
      "destination": "/api/index.py"
    },
    {
      "source": "/docs/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/redoc",
      "destination": "/api/index.py"
    },
    {
      "source": "/redoc/(.*)",
      "destination": "/api/index.py"
    }
  ]
}
